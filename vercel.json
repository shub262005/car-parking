{
  "version": 2,
  "builds": [
    { "src": "api/config.js", "use": "@vercel/node" },
    { "src": "index.html",    "use": "@vercel/static" },
    { "src": "style.css",     "use": "@vercel/static" },
    { "src": "script.js",     "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/config", "dest": "/api/config.js" },
    { "src": "/(.*\\.(css|js))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
